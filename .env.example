# ====================================================================
# Happy Greens — Environment Variable Reference (.env.example)
# ====================================================================
# Copy the relevant sections into each project's .env file.
# NEVER commit real secrets. This file is safe to commit.
# ====================================================================


# ============================================================
# BACKEND  →  happy-greens-backend/.env
# ============================================================

# ----- Server -----
PORT=3000
NODE_ENV=development                          # development | production

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# ----- CORS -----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ----- JWT -----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ----- Frontend URL (used in password reset emails) -----
FRONTEND_URL=http://localhost:5175

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

# ----- Razorpay -----
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET

# ----- Email / SMTP (leave blank to mock emails to console) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ----- Fast2SMS / SMS OTP (leave blank to mock SMS to console) -----`r`nFAST2SMS_API_KEY=YOUR_FAST2SMS_API_KEY


# ============================================================
# STOREFRONT  →  happy-greens-frontend/.env
# ============================================================
# All keys must start with VITE_ to be exposed to the browser

VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000/api
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID


# ============================================================
# ADMIN DASHBOARD  →  happy-greens-admin/.env
# ============================================================
# All keys must start with VITE_ to be exposed to the browser

VITE_API_BASE_URL=http://localhost:3000/api
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

