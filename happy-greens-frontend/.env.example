VITE_GOOGLE_CLIENT_ID=
VITE_API_BASE_URL=https://happy-greens-18n3.onrender.com/api
# Native Android/iOS Google Sign-In also uses VITE_GOOGLE_CLIENT_ID as the web client ID.
# Android additionally needs a Google Cloud Android OAuth client for package com.happygreens.app and its SHA-1.
# iOS needs GOOGLE_IOS_CLIENT_ID and GOOGLE_IOS_REVERSED_CLIENT_ID set in Xcode build settings.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
