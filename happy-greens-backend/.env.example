# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/happy_greens

# JWT Secret (REQUIRED)
JWT_SECRET=your_strong_jwt_secret_here_minimum_32_characters

# Server Configuration
PORT=3000
NODE_ENV=development

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Fast2SMS OTP
FAST2SMS_API_KEY=your_fast2sms_api_key

# MSG91 OTP
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_FLOW_ID=your_msg91_flow_id
MSG91_SENDER_ID=your_msg91_sender_id
MSG91_OTP_VARIABLE=OTP

# Email / SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=noreply@happygreensonline.com
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
FRONTEND_URL=https://www.happygreensonline.com

# Firebase Phone Auth (backend verification)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"


# Admin Dashboard Credentials
ADMIN_EMAIL=your_admin_email
ADMIN_PASSWORD=your_admin_password
ADMIN_FULL_NAME=Admin User


# Cloudinary (persistent media storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=happy-greens

